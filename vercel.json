{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/index.php",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about.php",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/customer/index.php",
      "destination": "/customer",
      "permanent": true
    },
    {
      "source": "/customer/home.php",
      "destination": "/customer",
      "permanent": true
    },
    {
      "source": "/customer/booking/create.php",
      "destination": "/customer/booking/create",
      "permanent": true
    },
    {
      "source": "/admin/index.php",
      "destination": "/admin",
      "permanent": true
    },
    {
      "source": "/admin/fields/index.php",
      "destination": "/admin/fields",
      "permanent": true
    },
    {
      "source": "/admin/bookings/index.php",
      "destination": "/admin/bookings",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path*.(svg|png|jpg|jpeg|gif|webp|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
